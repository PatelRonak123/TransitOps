.poetry.lock

# Jupyter Notebook
.ipynb_checkpoints

# IPython
.ipython

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms/python versions,
#   Pipfile.lock might need to be ignored.
# Pipfile.lock

# poetry
#   Similarly, poetry.lock can be ignored if you want.
# poetry.lock

# pdm
#   Similar to Pipfile.lock / poetry.lock
.pdm-python

# PEP 582; modern python package management without venv
__pypackages__/

